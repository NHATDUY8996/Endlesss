        .mobile-mxh
            h3.mobile-title
                | Theo dõi chúng tôi trên
            +social("",[{images: "social-1.png"},{images: "social-2.png"},{images: "social-3.png"},{images: "social-4.png"},{images: "social-5.png"}],"")

    +popup("popup-success","book-success","fa-solid fa-xmark")
        .success
            .success-img 
                +img("success.png")
            .success-desc 
                h3.title-pri.t-cpri.f-pri.t-upper Success! Your Journey Starts Here.
                .desc Thank you for reaching out. We’ve received your details. Mo is now reviewing your travel vision to see how we can best craft an experience that resonates with your soul.
                +btn("Back to Home","btn-sec btn-icon btn-main","","next.png","","")


    +popup("bookcall","book-call","fa-solid fa-xmark")
        .ctact-frm 
            form(action="")
                .ctact-frm-inner 
                    .ctact-frm-head 
                        p.title-tag CONTACT FORM
                        +ttp("Start the Conversation",
                            "",
                            "t-cpri t-upper f-pri txt-spl",
                            "")
                        p.desc After you share your context, we’ll start crafting the magic.
                    .ctact-frm-bdy 
                        .frm-row.row 
                            .frm-col.col.col-6
                                .frm-item 
                                    .frm-ip
                                        input.frm-input(type="text" placeholder="First name*")
                            .frm-col.col.col-6
                                .frm-item 
                                    .frm-ip
                                        input.frm-input(type="text" placeholder="Last name*")
                            .frm-col.col.col-6
                                .frm-item 
                                    .frm-ip
                                        input.frm-input(type="tel" placeholder="Your phone number*")
                            .frm-col.col.col-6
                                .frm-item 
                                    .frm-ip
                                        input.frm-input(type="email" placeholder="Your email*")
                            .frm-col.col
                                .frm-item 
                                    .frm-ip
                                        .dateTime(data-type="single")
                                            .dateTimeItem.dateFrom
                                                .dateTimeText
                                                    | ngày/tháng/năm
                                                input.dateTimeInput(type="text" name="arrivaldate" placeholder="") 
                                                .icon
                                                    +img("date.png")
                            .frm-col.col
                                .frm-item 
                                    label.frm-lb Choose your wanted destinations*
                                    .frm-recheck 
                                        - 
                                            const destinations = ["Phong Nha", "Hue", "Hoi An", "Khe Sanh", "Central Highlands", "Con Dao"];
                                        each des in destinations
                                            .recheck-item
                                                input.recheck-input(type="checkbox" id=`check-${des}`)
                                                label.recheck-des(for=`check-${des}`) #{des}
                            .frm-col.col
                                .frm-item 
                                    label.frm-lb Who are you traveling with?*
                                    .frm-recheck 
                                        - 
                                            const travelers = ["Family", "Friends", "Partner", "My own"];
                                        each traveler in travelers
                                            .recheck-item
                                                input.recheck-input(type="checkbox" id=`check-${traveler}`)
                                                label.recheck-des(for=`check-${traveler}`) #{traveler}
                            .frm-col.col
                                .frm-item 
                                    label.frm-lb What would you like to do? *
                                    .frm-recheck 
                                        - 
                                            const activities = ["Nature & Scenery", "Activities & Sports", "Relaxing & Wellness", "Culture & Rural life"];
                                        each activity in activities
                                            .recheck-item
                                                input.recheck-input(type="checkbox" id=`check-${activity}`)
                                                label.recheck-des(for=`check-${activity}`) #{activity}

                            .frm-col.col
                                .frm-item
                                    .frm-ip
                                        textarea.frm-input(rows="5" placeholder="Message")
                        .ctact-btn 
                            +btn("Send message","btn-sec btn-icon btn-main","","next.png","","")
                            p.desc *Average design time: 24 hours 

    .mncart-overlay
    .mncart 
        .mncart-wr
            .mncart-close 
                i.fa-solid.fa-xmark
            .mncart-bdy
                .mncart-head 
                    h4.mncart-tt SELECTED EXPERIENCES
                    a.mncart-link(href="") 
                        +img("minicart-link.png")

                .mncart-inner
                    .mncart-list
                        each i,index in Array(7)
                            .mncart-item
                                p.numb #{index + 1}
                                .pduct
                                    .pduct-img 
                                        .pduct-img-inner 
                                            +img("pduct-1.jpg")
                                    .pduct-desc
                                        .pduct-desc-inner
                                            p.pduct-desc-tag Hue
                                            h3.pduct-tt
                                                a.link(href="") Hue Street Food & Heritage Ride
                                            ul.pduct-list 
                                                li.pduct-item
                                                    span.txt Adult 
                                                        span.text 
                                                            span.bold  $95
                                                            |/person
                                                li.pduct-item
                                                    span.txt Child 
                                                        span.text
                                                            span.bold  $75
                                                            |/person

            .mncart-gr 
                +btn("Request My Master Plan","btn-sec btn-main btn-icon","","next.png","","")

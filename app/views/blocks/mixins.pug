mixin bnfItem(icon, title, content)
    .bnf-item 
        .wrap 
            .icon 
                +img(icon)
            h3.tt= title
            p.content= content

mixin partnerItem(br,title,classCustom)
    .partner-item 
        .in 
            .br-img 
                +img(br)
            h3.tt= title

mixin thumb()
    section.sec-thumb
        .thumb
            .thumb-wr
                .thumb-bg
                    .inner
                        +img("thumb-bg.jpg")
                .container
                    .thumb-bdy
                        .thumb-desc 
                            +ttp("STOP PLANNING. START DREAMING.!",
                                "tt-center",
                                "t-cwhite txt-spl",
                                "")
                            p.desc(data-aos="fade-up" data-aos-delay="200") Pick your favorite local experiences and let Mơ weave them into a sophisticated, unhurried, and safe master plan tailored just for you.
                            .thumb-btn(data-aos="fade-up" data-aos-delay="400")
                                +btn("Start Building Your Journey","btn-sec btn-icon btn-main","","next.png","","")

mixin journalItem(thumb)
    .journal-item 
        .wrap 
            .journal-thumb 
                a.journal-thumb-in(href="")
                    +img(thumb)
            .journal-content 
                .journal-info 
                    .t-tag 
                        span.txt Eco-Friendly Stays
                    .t-date Nov 25, 2026
                h3
                    a(href="").journal-tt The future of sustainable logistics: 5 trends to watch in 2025
                p.journal-desc Located in the heart of central Vietnam, Phong Nha-Kẻ Bàng National Park is home to the most awe-inspiring caves and lush landscapes in the country. With its stunning natural beauty, unique wildlife, and rich cultural history, Phong Nha is a dream destination for adventure seekers and nature lovers alike.

                            .col-lf-wrap
                                .head-gr
                                    .icon 
                                        +img("ic-h.png")
                                    +ttp("Những con số nổi bật",
                                        "mb-12",
                                        "t-sec txt-spl",
                                        "")
                                    p.txt 17 năm tiên phong xuất bản và phát hành sách ngoại ngữ
                        .col-rt.col.col-6

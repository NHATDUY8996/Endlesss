extends layout/layout
block vars
    -title = 'NamePage'
    -mainClass = 'page-template'
    -bodyClass = ''
    -hdClass = ''

block container
    section.sec-ctinfo
        .ctinfo.pd-100
            .ctinfo-wr 
                .ctinfo-head.mb-40
                    +breadCrumb([{txt: "Contact us"}])
                    .container 
                        +ttp("contact us",
                            "",
                            "t-cpri f-100 t-upper txt-spl",
                            "")
                .container 
                    .ctinfo-bdy 
                        .ctinfo-map.mb-48
                            .inner 
                                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3806.30656268519!2d106.57762267591134!3d17.44503520114032!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3147567d15c385f1%3A0xc77cf9179d7d8fa!2zMjQgUGhhbiDEkMSDbmcgTMawdSwgxJDhu5NuZyBTxqFuLCBRdeG6o25nIFRy4buLIDUxMDAwMCwgVmnhu4d0IE5hbQ!5e0!3m2!1svi!2s!4v1775467807151!5m2!1svi!2s" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>

                        .ctinfo-desc 
                            .ctinfo-desc-head 
                                +ttp("YOUR TIME IN VIETNAM IS LIMITED.<br> <span class=\"title-span\">USE IT WISELY.</span>",
                                    "mb-16",
                                    "t-cpri t-upper f-pri txt-spl",
                                    "")
                                .mona-content 
                                    p From iconic routes to untouched landscapes, we partner with top local hosts to create a trip as unique as you.
                                    p Share your preferences via our survey, and let’s build your story together.
                            .ctinfo-list 
                                .ctinfo-item 
                                    p.tt Visit Our Studio
                                    a.link(href="")  24 Phan Dang Luu, Dong Son, Quang Tri, Vietnam
                                .ctinfo-item
                                    p.tt hotline
                                    a.link(href="tel:+84987654321") +84 972916588
                                .ctinfo-item
                                    p.tt Email
                                    a.link(href="") xinchao@endlessvietnam.com
                                .ctinfo-item
                                    p.tt follow us
                                    +social("",[{images: "sc-1.png"},{images: "sc-2.png"},{images: "sc-3.png"}],"")

    section.sec-ctact
        .ctact
            .ctact-bg 
                .inner 
                    +img("ctact-bg.jpg")
            .ctact-wr 
                .container 
                    .ctact-bdy
                        .ctact-frm 
                            form(action="")
                                .ctact-frm-inner 
                                    .ctact-frm-head 
                                        p.title-tag CONTACT FORM
                                        +ttp("Start the Conversation",
                                            "",
                                            "t-cpri t-upper f-pri txt-spl",
                                            "")
                                        p.desc After you share your context, we’ll start crafting the magic.
                                    .ctact-frm-bdy 
                                        .frm-row.row 
                                            .frm-col.col.col-6
                                                .frm-item 
                                                    .frm-ip
                                                        input.frm-input(type="text" placeholder="First name*")
                                            .frm-col.col.col-6
                                                .frm-item 
                                                    .frm-ip
                                                        input.frm-input(type="text" placeholder="Last name*")
                                            .frm-col.col.col-6
                                                .frm-item 
                                                    .frm-ip
                                                        input.frm-input(type="tel" placeholder="Your phone number*")
                                            .frm-col.col.col-6
                                                .frm-item 
                                                    .frm-ip
                                                        input.frm-input(type="email" placeholder="Your email*")
                                            .frm-col.col
                                                .frm-item 
                                                    .frm-ip
                                                        .dateTime(data-type="single")
                                                            .dateTimeItem.dateFrom
                                                                .dateTimeText
                                                                    | ngày/tháng/năm
                                                                input.dateTimeInput(type="text" name="arrivaldate" placeholder="") 
                                                                .icon
                                                                    +img("date.png")
                                            .frm-col.col
                                                .frm-item 
                                                    label.frm-lb Choose your wanted destinations*
                                                    .frm-recheck 
                                                        - 
                                                            const destinations = ["Phong Nha", "Hue", "Hoi An", "Khe Sanh", "Central Highlands", "Con Dao"];
                                                        each des in destinations
                                                            .recheck-item
                                                                input.recheck-input(type="checkbox" id=`check-${des}`)
                                                                label.recheck-des(for=`check-${des}`) #{des}
                                            .frm-col.col
                                                .frm-item 
                                                    label.frm-lb Who are you traveling with?*
                                                    .frm-recheck 
                                                        - 
                                                            const travelers = ["Family", "Friends", "Partner", "My own"];
                                                        each traveler in travelers
                                                            .recheck-item
                                                                input.recheck-input(type="checkbox" id=`check-${traveler}`)
                                                                label.recheck-des(for=`check-${traveler}`) #{traveler}
                                            .frm-col.col
                                                .frm-item 
                                                    label.frm-lb What would you like to do? *
                                                    .frm-recheck 
                                                        - 
                                                            const activities = ["Nature & Scenery", "Activities & Sports", "Relaxing & Wellness", "Culture & Rural life"];
                                                        each activity in activities
                                                            .recheck-item
                                                                input.recheck-input(type="checkbox" id=`check-${activity}`)
                                                                label.recheck-des(for=`check-${activity}`) #{activity}

                                            .frm-col.col
                                                .frm-item
                                                    .frm-ip
                                                        textarea.frm-input(rows="5" placeholder="Message")
                                        .ctact-btn 
                                            +btn("Send message","btn-sec btn-icon btn-main","","next.png","","")
                                            p.desc *Average design time: 24 hours


